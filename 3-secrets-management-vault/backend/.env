# (EN: Vault connection settings — bootstrap secrets only, all runtime secrets come from Vault)
# (VI: Cấu hình kết nối Vault — chỉ bootstrap secrets, mọi runtime secrets lấy từ Vault)
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=<replace-with-role-id>
VAULT_SECRET_ID=<replace-with-secret-id>

# (EN: Application port)
# (VI: Cổng ứng dụng)
PORT=3000
